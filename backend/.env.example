# This app does not auto-load `.env` files (no `dotenv` dependency), so
# copying this to `.env` alone does nothing at runtime -- `source` it, use
# `env $(cat .env | xargs) npm run dev`, or (recommended) set these as real
# environment variables via your shell / process manager / hosting provider.
# Every value below is a placeholder / documented default -- no real secrets.

# TCP port the Fastify server listens on. Must be an integer in 1-65535.
PORT=8080

# Interface/address to bind to. Use 0.0.0.0 in containers so the process is
# reachable from outside the container's network namespace.
HOST=0.0.0.0

# How often (ms) the background job rebuilds the tonight snapshot from
# MET/NOAA. Must be a positive number.
REFRESH_MS=300000

# Bearer-style token required (as the `x-admin-token` header) to call
# POST /v1/admin/refresh. CHANGE THIS -- the value below is a placeholder,
# not a real credential. Leaving it unset fails the route closed (every
# request is rejected with 401), it never silently opens the route.
ADMIN_TOKEN=change-me

# Comma-separated list of frontend origins allowed to call this API via CORS.
# Defaults to local Expo web dev origins only; set this explicitly in any
# deployed environment.
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# How old (ms) the on-disk mirrored snapshot (backend/data/latest-snapshot.json)
# can be before /v1/health flags it as stale after a restart. Must be a
# positive number.
STALE_SNAPSHOT_MS=1800000

# Timeout (ms) applied to every outbound call to MET/NOAA before falling
# back to deterministic sample data. Must be a positive number.
SOURCE_TIMEOUT_MS=10000
