# This app does not auto-load `.env` files (no `dotenv` dependency), so
# copying this to `.env` alone does nothing at runtime -- `source` it, use
# `env $(cat .env | xargs) npm run dev`, or (recommended) set these as real
# environment variables via your shell / process manager / hosting provider.
# Every value below is a placeholder / documented default -- no real secrets.

# TCP port the Fastify server listens on. Must be an integer in 1-65535.
PORT=8080

# Interface/address to bind to. Use 0.0.0.0 in containers so the process is
# reachable from outside the container's network namespace.
HOST=0.0.0.0

# How often (ms) the background job rebuilds the tonight snapshot from
# MET/NOAA. Must be a positive number.
REFRESH_MS=300000

# Bearer-style token required (as the `x-admin-token` header) to call
# POST /v1/admin/refresh. CHANGE THIS -- the value below is a placeholder,
# not a real credential. Leaving it unset fails the route closed (every
# request is rejected with 401), it never silently opens the route.
ADMIN_TOKEN=change-me

# Comma-separated list of frontend origins allowed to call this API via CORS.
# Defaults to local Expo web dev origins only; set this explicitly in any
# deployed environment.
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# How old (ms) the on-disk mirrored snapshot (backend/data/latest-snapshot.json)
# can be before /v1/health flags it as stale after a restart. Must be a
# positive number.
STALE_SNAPSHOT_MS=1800000

# Timeout (ms) applied to every outbound call to MET/NOAA before falling
# back to deterministic sample data. Must be a positive number.
SOURCE_TIMEOUT_MS=10000

# How many days a usage-counter hour bucket (type|spotId|hourBucket, see
# src/usageStore.ts) is retained before being pruned from memory and from
# backend/data/usage-stats.json, on both server boot and every periodic
# flush. Must be a positive number -- 0, negative, or invalid (non-numeric)
# values fall back to the default of 180.
USAGE_RETENTION_DAYS=180

# Small-cell/k-anonymity suppression threshold for GET /v1/stats/usage
# (src/stats.ts). 0 (default) means suppression is off -- every breakdown
# entry is returned. When set > 0, bySpot/byHour/byDay entries with a count
# below this value are omitted from the response (totals stay exact).
# Negative or invalid (non-numeric) values fall back to 0 (= off), same as
# leaving it unset. The owner should set a real value before this endpoint's
# output leaves the org.
STATS_MIN_CELL=0

# --- Aurora push alerts (src/alerts.ts, src/fcm.ts) ---
# OWNER-HELD SECRETS -- both are unset here on purpose (real values are never
# committed). Leaving either unset (or both) is a fully supported, safe
# configuration: the alerts engine still evaluates triggers and persists
# state, but the FCM publish step is INERT -- it logs one info line
# ("alerts engine active, publisher unconfigured") and skips sending. See
# docs/setup-firebase-alerts.md for how the owner generates these.

# Firebase project id (the publish target is
# projects/<FCM_PROJECT_ID>/messages:send).
# FCM_PROJECT_ID=your-firebase-project-id

# The Firebase service account key, as a single JSON string (NOT a path to a
# file) -- this is the exact JSON Firebase gives you when you generate a key
# (Project settings -> Service accounts -> Generate new private key), with no
# re-encoding needed. Inline JSON (rather than a file path) was chosen
# because this app's deploy target (Fly, see ../fly.toml) sets secrets as
# plain env var values (`flyctl secrets set`), which can't easily mount a
# file without an extra volume. Never commit a real value.
# FCM_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com", ...}
