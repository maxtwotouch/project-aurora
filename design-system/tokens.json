{
  "$note": "Platform-agnostic mirror of tokens.ts, for tooling that isn't a React Native/TypeScript consumer (design tools, a future web-only sibling app, a Style Dictionary pipeline, etc). Hand-synced, not generated -- if you change a value in tokens.ts, make the same change here in the same commit. There is no build step wiring these two files together; tokens.ts is the source of truth read by the app, this file is a convenience export for everything else. motion.easing is expressed as cubic-bezier control points (same numbers passed to react-native's Easing.bezier() in tokens.ts) since JSON can't hold a function.",
  "ground": {
    "base": "#061617",
    "soft": "#0d2023",
    "panel": "#132d30",
    "surface": "#14292d",
    "surfaceElevated": "#193639",
    "borderSubtle": "#336163",
    "borderStrong": "#4d8887"
  },
  "text": {
    "primary": "#eef7f4",
    "secondary": "#bdd0cf",
    "muted": "#9db1b1",
    "onSignal": "#04110d",
    "onInfoSurface": "#d5ecff",
    "onWarningSurface": "#fae7a3",
    "onDangerSurface": "#ffd2d8",
    "onAccentWarmSurface": "#f6cbb0"
  },
  "signal": {
    "primary": "#67efc1",
    "soft": "#b5ffd9",
    "info": "#89bfff",
    "infoTint": "#d5ecff",
    "deep": "#1f8a71",
    "glow": "#7cf2c7"
  },
  "accentWarm": {
    "base": "#d97b52",
    "surface": "#3a2418",
    "onSurface": "#f6cbb0"
  },
  "status": {
    "warning": "#f4c95d",
    "danger": "#ef7f8b",
    "successSurface": "#16352d",
    "infoSurface": "#162c40",
    "warningSurface": "#403518",
    "dangerSurface": "#41202a"
  },
  "surface": {
    "sunken": "#102527",
    "sunkenAlt": "#153335",
    "overlay": "#0f2426",
    "chip": "#173c3c",
    "chipActive": "#1d484a"
  },
  "border": {
    "hairline": "#285657",
    "hairlineStrong": "#356568"
  },
  "glow": {
    "mint": "#82f3c41f",
    "blue": "#91beff14"
  },
  "shadow": "#000000",
  "spacing": {
    "xxs": 4,
    "xs": 8,
    "sm": 12,
    "md": 16,
    "lg": 20,
    "xl": 28,
    "xxl": 40,
    "xxxl": 56
  },
  "radius": {
    "sm": 12,
    "md": 16,
    "lg": 20,
    "xl": 26,
    "pill": 999
  },
  "elevation": {
    "sm": {
      "shadowColor": "#000000",
      "shadowOffset": { "width": 0, "height": 8 },
      "shadowOpacity": 0.18,
      "shadowRadius": 14,
      "elevation": 4
    },
    "lg": {
      "shadowColor": "#000000",
      "shadowOffset": { "width": 0, "height": 16 },
      "shadowOpacity": 0.26,
      "shadowRadius": 26,
      "elevation": 8
    }
  },
  "motion": {
    "duration": {
      "fast": 140,
      "base": 260,
      "slow": 420,
      "enter": 560
    },
    "easing": {
      "out": { "cubicBezier": [0.16, 1, 0.3, 1] },
      "inOut": { "cubicBezier": [0.65, 0, 0.35, 1] }
    }
  },
  "typography": {
    "fontFamilies": {
      "displaySerif": {
        "medium": "Fraunces_600SemiBold",
        "bold": "Fraunces_700Bold",
        "black": "Fraunces_900Black",
        "$note": "String names only -- loading these fonts (useFonts from @expo-google-fonts/fraunces) is app-side. See tokens.ts's fraunces export doc comment."
      },
      "ui": "system"
    },
    "scale": {
      "eyebrow": { "fontSize": 11, "lineHeight": 14, "fontWeight": 800, "letterSpacing": 1.2, "textTransform": "uppercase" },
      "caption": { "fontSize": 12, "lineHeight": 16, "fontWeight": 600 },
      "bodySmall": { "fontSize": 13, "lineHeight": 19, "fontWeight": 500 },
      "body": { "fontSize": 15, "lineHeight": 22, "fontWeight": 400 },
      "bodyStrong": { "fontSize": 15, "lineHeight": 22, "fontWeight": 700 },
      "subheading": { "fontSize": 17, "lineHeight": 23, "fontWeight": 700 },
      "heading": { "fontSize": 20, "lineHeight": 25, "fontWeight": 800 },
      "title": { "fontFamily": "Fraunces_700Bold", "fontSize": 26, "lineHeight": 31, "fontWeight": 700 },
      "display": { "fontFamily": "Fraunces_600SemiBold", "fontSize": 38, "lineHeight": 43, "fontWeight": 600 },
      "numeralMd": { "fontFamily": "Fraunces_700Bold", "fontSize": 26, "lineHeight": 30, "fontWeight": 700, "fontVariant": ["tabular-nums"] },
      "numeralLg": { "fontFamily": "Fraunces_900Black", "fontSize": 56, "lineHeight": 58, "fontWeight": 900, "fontVariant": ["tabular-nums"] }
