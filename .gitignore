node_modules
.expo
.expo-shared
dist
npm-debug.*
yarn-debug.*
yarn-error.*
.DS_Store
.env

# Aggregate-only usage counters mirror (backend/src/usageStore.ts). Not
# latest-snapshot.json's sibling by intent: that file is tracked, this one
# isn't, since it's a locally-regenerated cache of in-memory counters.
backend/data/usage-stats.json

# Aurora alerts night-key/fired-tier state mirror (backend/src/alerts.ts).
# Same reasoning as usage-stats.json above: a locally-regenerated cache, not
# a seed file worth tracking. Contains no user data -- just {nightKey,
# firedTiers, totalFired}, see alerts.ts's PersistedAlertState.
backend/data/alerts-state.json

# Scoring-validation loop prediction/observed-outcome logs
# (backend/src/validation.ts). Same reasoning as usage-stats.json /
# alerts-state.json above: locally-regenerated, ever-growing logs (pruned by
# VALIDATION_RETENTION_DAYS), not seed files worth tracking. Contains no user
# data -- only our own model's predicted scores/windows and NOAA's publicly
# published measured Kp, see validation.ts's PredictionRecord/ObservedNightRecord.
backend/data/predictions.jsonl
backend/data/observed.jsonl

.worktrees/.worktrees/
.worktrees/

# Firebase native config for aurora push alerts (PR beta,
# docs/design-aurora-alerts.md / docs/setup-firebase-alerts.md section 5).
# Neither file is a secret on its own (they're bundled into shipped app
# binaries and are not treated as sensitive by Firebase/Google), but they
# are owner-held and app-instance-specific -- see app.config.js's
# withFirebaseIfConfigured for how their mere presence/absence changes what
# gets built. Ignored here defensively so a local `Generate new... /
# download` never gets committed by accident; the owner adds them locally
# (repo root) or via EAS's own credentials/secret-file mechanism.
/google-services.json
/GoogleService-Info.plist
